    },
    {
      "name": "test",
      "aws_account_id": "515614487430",
      "aws_region": "us-east-1"
    },
    {
      "name": "prod",
      "aws_account_id": "748285530646",
      "aws_region": "us-east-1"
    }
  ],
  "github": {
    "production_environment": "prod",
    "reviewer_teams": [],
    "wait_timer": 0
  },
  "ruleset": {
    "ruleset_enabled": true,
