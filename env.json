{
  "_comment": "Sample project configuration consumed by the aws-project-onboarding reusable workflow. Fill in the values for your project and commit this file at the repository root.",
  "hcp": {
    "_comment": "HCP Terraform workspace settings",
    "hcp_org": "subhamay-aws-projects",
    "terraform_version": "1.7.0",
    "execution_mode": "remote",
    "working_directory": "tf/",
    "branch": "main",
    "auto_apply": false,
    "tfe_address": "https://app.terraform.io",
